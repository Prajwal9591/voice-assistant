# =============================================================
#  J.A.R.V.I.S. — Python AI Voice Assistant  |  .gitignore
# =============================================================

# -------------------------------------------------------------
# SECRETS & ENVIRONMENT CONFIGURATION  ← NEVER COMMIT THESE
# -------------------------------------------------------------
.env
.env.*
!.env.example
*.key
*.pem
secrets.json
config.secret.*


# -------------------------------------------------------------
# PYTHON BYTECODE & COMPILED FILES
# -------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyd


# -------------------------------------------------------------
# VIRTUAL ENVIRONMENTS
# -------------------------------------------------------------
.venv/
venv/
env/
ENV/
.python-version


# -------------------------------------------------------------
# LOG FILES
# -------------------------------------------------------------
*.log
logs/
*.log.*


# -------------------------------------------------------------
# JARVIS RUNTIME DATA (auto-generated, not source code)
# -------------------------------------------------------------
memory_store/
vector_store/
cache/
temp/
tmp/
*.npy
*.pkl
*.pickle


# -------------------------------------------------------------
# EDITOR & IDE SETTINGS
# -------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/


# -------------------------------------------------------------
# BUILD & DISTRIBUTION ARTIFACTS
# -------------------------------------------------------------
build/
dist/
*.egg-info/
*.egg
.eggs/
wheels/
sdist/
develop-eggs/
lib/
lib64/
parts/
var/
htmlcov/
.tox/
.nox/


# -------------------------------------------------------------
# TESTING & COVERAGE
# -------------------------------------------------------------
.coverage
.pytest_cache/
.hypothesis/
coverage.xml
nosetests.xml
test-results/


# -------------------------------------------------------------
# OS-GENERATED FILES
# -------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~


# -------------------------------------------------------------
# TRACKED FILES — explicitly kept (for clarity)
# -------------------------------------------------------------
# !*.py              ← all source code tracked
# !requirements.txt  ← dependency list tracked
# !README.md         ← documentation tracked
# !.env.example      ← safe template tracked (no real secrets)
